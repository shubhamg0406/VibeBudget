# Copy this file to `.env.local` for local development.
# Never commit real Firebase values to the repo.

VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
VITE_FIREBASE_DATA_NAMESPACE="local-dev"
FIREBASE_DATA_NAMESPACE="local-dev"
FIREBASE_ADMIN_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'
FIREBASE_ADMIN_CREDENTIALS_PATH=""
ALLOW_FIREBASE_REST_FALLBACK="false"
AI_CHAT_CACHE_TTL_MS="300000"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
VITE_TEST_USER_EMAIL="shubhamg266@gmail.com"

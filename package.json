{
  "name": "vibebudget",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm:dev:api\" \"npm:dev:vite\"",
    "dev:vite": "vite --host --port 8888",
    "build:api": "esbuild server.ts --bundle --platform=node --format=cjs --target=node20 --outfile=.server-dist/server.cjs --external:better-sqlite3 --external:vite --external:@vitejs/plugin-react --external:@tailwindcss/vite --external:tailwindcss --external:lightningcss --external:fsevents --external:@tailwindcss/oxide* --external:@babel/preset-typescript/package.json",
    "dev:api": "npm run build:api && NODE_ENV=production PORT=3000 node .server-dist/server.cjs",
    "dev:test": "VITE_TEST_MODE=mock vite --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "preview": "vite preview --host",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:component && npm run test:api && npm run test:smoke",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/components",
    "test:api": "vitest run --environment=node tests/api",
    "test:smoke": "playwright test",
    "verify": "node ./scripts/verify.mjs",
    "agent:start": "node scripts/agent-start.mjs",
    "agent:pr": "node scripts/agent-pr.mjs",
    "agent:whoami": "node scripts/agent-whoami.mjs"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.8.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "jsdom": "^24.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
